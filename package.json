{
  "name": "MCLegacy",
  "version": "1.0.0",
  "description": "A Minecraft: Legacy Console Edition launcher",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder --linux AppImage",
    "dist:flatpak": "electron-builder --linux flatpak",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.mclegacy.app",
    "productName": "MCLegacy",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "flatpak"
      ],
      "category": "Game",
      "icon": "512x512.png",
      "desktop": {
        "entry": {
          "Name": "MCLegacy",
          "GenericName": "Minecraft Launcher",
          "Comment": "A Minecraft: Legacy Console Edition launcher",
          "Categories": "Game;Emulation;",
          "StartupNotify": "true"
        }
      },
      "executableName": "mclegacy"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "512x512.png",
      "category": "public.app-category.games"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^6.0.1",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1"
  }
}
